# Homestay Management System - Environment Configuration
# Copy this file to .env and adjust values as needed

# PostgreSQL Database URL (async driver for application)
# Format: postgresql+asyncpg://user:password@host:port/database
HOMESTAY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/homestay

# PostgreSQL Database URL (sync driver for Alembic migrations)
# Format: postgresql://user:password@host:port/database
HOMESTAY_DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/homestay

# Availability Window (days to pre-generate for new rooms)
# Default: 365
HOMESTAY_AVAILABILITY_WINDOW_DAYS=365
